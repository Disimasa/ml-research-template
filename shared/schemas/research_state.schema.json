{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research_state.schema.json",
  "title": "Research Pipeline State",
  "type": "object",
  "required": ["mode", "pipeline_profile", "current_phase"],
  "properties": {
    "mode": { "type": "string", "enum": ["hitl", "autonomous"] },
    "pipeline_profile": { "type": "string" },
    "phases_enabled": { "type": "array", "items": { "type": "string" } },
    "current_phase": { "type": "string" },
    "pending_approval": { "type": "boolean" },
    "approved_by": { "type": ["string", "null"] },
    "autonomous": { "type": "object" }
  }
}
